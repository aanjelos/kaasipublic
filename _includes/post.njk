---
layout: layout.njk
isPost: true
---
<article class="pt-40 pb-24">
  <div class="container mx-auto px-6 max-w-4xl">
    <header class="text-center mb-16 animate-fade-in-up">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 md:leading-tight">
        {{ title }}
      </h1>
      <div class="flex items-center justify-center gap-4 text-gray-400">
        <div class="flex items-center gap-3">
          <img
            src="/blog/img/author/blog-aanjelo.jpg"
            alt="{{ author }}"
            class="w-10 h-10 rounded-full"
            onerror="this.onerror=null; this.src='https://placehold.co/40x40/1a1a1a/e67e26?text=A&font=satoshi';"
          />
          <span>{{ author }}</span>
        </div>
        <span class="text-gray-600">&bull;</span>
        <span id="post-date">{{ date | dateFilter }}</span>
      </div>
    </header>

    {% if image %}
    <div class="mb-12 animate-fade-in-up" style="--delay: 0.2s">
      <img
        id="post-image"
        src="{{ image }}"
        onerror="this.onerror=null; this.src='https://placehold.co/1200x600/18181b/3f3f46?text=Blog+Image';"
        alt="{{ title }}"
        class="w-full h-auto max-h-[500px] object-cover rounded-xl border border-gray-800"
      />
    </div>
    {% endif %}

    <div
      id="post-content"
      class="prose prose-invert max-w-none animate-fade-in-up"
      style="--delay: 0.4s"
    >
      {{ content | safe }}
    </div>

    
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4 animate-fade-in-up" style="--delay: 0.5s">
        <span class="text-gray-400 font-medium">Share this post</span>
        <div class="flex items-center gap-4">
            <a href="https://twitter.com/intent/tweet?url=https://kaasi.com.lk{{ page.url }}&text={{ title | urlencode }}" target="_blank" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400 hover:bg-black hover:text-white transition-colors">
                <i class="fa-brands fa-x-twitter"></i>
            </a>
            <a href="https://www.facebook.com/sharer/sharer.php?u=https://kaasi.com.lk{{ page.url }}" target="_blank" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#4267B2] hover:text-white transition-colors">
                <i class="fab fa-facebook-f"></i>
            </a>
            <a href="https://www.linkedin.com/shareArticle?mini=true&url=https://kaasi.com.lk{{ page.url }}&title={{ title | urlencode }}" target="_blank" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#0077b5] hover:text-white transition-colors">
                <i class="fab fa-linkedin-in"></i>
            </a>
            <a href="https://api.whatsapp.com/send?text={{ title | urlencode }}%20https://kaasi.com.lk{{ page.url }}" target="_blank" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#25D366] hover:text-white transition-colors">
                <i class="fab fa-whatsapp"></i>
            </a>
            <button class="copy-button w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center text-gray-400 hover:bg-orange-500 hover:text-white transition-colors" data-copy-text="https://kaasi.com.lk{{ page.url }}">
                <i class="fas fa-link"></i>
            </button>
        </div>
    </div>

    <div class="mt-16 flex flex-col sm:flex-row justify-center gap-4 text-center animate-fade-in-up" style="--delay: 0.6s">
        <a href="/blog/" class="cta-button-secondary py-3.5 flex items-center justify-center">
            <i class="fas fa-arrow-left mr-2"></i> Back to All Posts
        </a>
        <a href="https://app.kaasi.com.lk/" target="_blank" class="cta-button cta-button-large flex items-center justify-center">
            <span>Try Kaasi Now</span>
            <i class="fas fa-arrow-right ml-2"></i>
        </a>
    </div>
  </div>
</article>
