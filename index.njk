---
layout: v2-layout.njk
title: "Kaasi - The Finance Engine for Serious Sri Lankans"
excerpt: "Kaasi is a personal finance tool built for Sri Lankans who want total control over every rupee. Track complex expenses, manage debts, credit cards, and installments. Offline-first, with no ads and no compromises."
---

<!-- 1. Scrollytelling Hero Section -->
<section class="hero-sticky-container bg-kaasi-bg" id="hero">
    <div class="hero-sticky-inner w-full">
        <!-- Hero Text -->
        <div class="hero-text-content text-center max-w-4xl px-6 absolute top-1/4 z-10 w-full left-1/2 -translate-x-1/2">
            <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight mb-6">
                Your Finances.<br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600">Uncompromised.</span>
            </h1>
            <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
                The offline-first personal finance engine for Sri Lankans who demand total control over every rupee.
            </p>
        </div>

        <!-- Dashboard Exploding Mockup -->
        <div class="relative w-full max-w-5xl px-6 aspect-video mt-24 z-0 flex items-center justify-center">
            
            <!-- Base Mockup -->
            <div id="mockup-base" class="mockup-layer w-full max-w-3xl aspect-[16/10] p-4 flex flex-col z-20">
                <!-- Title Bar -->
                <div class="flex gap-2 pb-3 border-b border-gray-800 mb-4">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                
                <div class="flex gap-4 h-full">
                    <!-- Sidebar -->
                    <div class="w-1/4 border-r border-gray-800 pr-4 flex flex-col gap-4">
                        <div class="h-8 bg-gray-800/50 rounded-lg w-full mb-4"></div>
                        <div class="h-4 bg-gray-800/30 rounded w-3/4"></div>
                        <div class="h-4 bg-gray-800/30 rounded w-1/2"></div>
                        <div class="h-4 bg-gray-800/30 rounded w-2/3"></div>
                    </div>
                    
                    <!-- Main Area -->
                    <div class="flex-1 flex flex-col gap-4">
                        <!-- Top Nav -->
                        <div class="h-12 bg-gray-800/20 border border-gray-800/50 rounded-xl w-full"></div>
                        
                        <!-- Content Area -->
                        <div class="flex-1 flex gap-4">
                            <!-- Transactions -->
                            <div class="w-2/3 bg-gray-800/20 border border-gray-800/50 rounded-xl p-4 flex flex-col gap-3">
                                <div class="h-6 w-32 bg-gray-700/50 rounded mb-2"></div>
                                <div class="h-12 w-full bg-gray-800/40 rounded flex items-center px-4 justify-between">
                                    <div class="h-3 w-24 bg-gray-700 rounded"></div>
                                    <div class="h-3 w-16 bg-red-500/50 rounded"></div>
                                </div>
                                <div class="h-12 w-full bg-gray-800/40 rounded flex items-center px-4 justify-between">
                                    <div class="h-3 w-32 bg-gray-700 rounded"></div>
                                    <div class="h-3 w-12 bg-green-500/50 rounded"></div>
                                </div>
                            </div>
                            
                            <!-- Summary -->
                            <div class="w-1/3 bg-gray-800/20 border border-gray-800/50 rounded-xl flex items-center justify-center">
                                <div class="w-24 h-24 rounded-full border-4 border-gray-700/50 flex items-center justify-center">
                                    <div class="w-16 h-16 rounded-full border-4 border-orange-500/50 border-t-transparent"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Floating Chart Layer (Breaks out on scroll) -->
            <div id="mockup-layer-chart" class="mockup-layer w-64 h-48 p-4 z-30 opacity-0 bg-kaasi-card/90 backdrop-blur-md">
                <div class="text-sm font-bold text-gray-300 mb-4">Analytics</div>
                <div class="h-full w-full flex items-end gap-2 pb-6">
                    <div class="w-full bg-orange-500/40 rounded-t h-[40%]"></div>
                    <div class="w-full bg-orange-500/60 rounded-t h-[60%]"></div>
                    <div class="w-full bg-orange-500/80 rounded-t h-[80%]"></div>
                    <div class="w-full bg-orange-500 rounded-t h-[100%]"></div>
                </div>
            </div>

            <!-- Floating List Layer (Breaks out on scroll) -->
            <div id="mockup-layer-list" class="mockup-layer w-72 h-64 p-4 z-30 opacity-0 bg-kaasi-card/90 backdrop-blur-md">
                <div class="text-sm font-bold text-gray-300 mb-4">Budgets</div>
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-xs mb-1"><span class="text-gray-400">Food</span> <span class="text-gray-300">80%</span></div>
                        <div class="h-2 w-full bg-gray-800 rounded-full overflow-hidden"><div class="h-full bg-red-500 w-[80%]"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-xs mb-1"><span class="text-gray-400">Transport</span> <span class="text-gray-300">45%</span></div>
                        <div class="h-2 w-full bg-gray-800 rounded-full overflow-hidden"><div class="h-full bg-orange-500 w-[45%]"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-xs mb-1"><span class="text-gray-400">Bills</span> <span class="text-gray-300">100%</span></div>
                        <div class="h-2 w-full bg-gray-800 rounded-full overflow-hidden"><div class="h-full bg-gray-500 w-[100%]"></div></div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</section>

<!-- 2. Interactive Glassmorphism Bento Grid -->
<section class="py-32 relative bg-kaasi-bg" id="features">
    <div class="container mx-auto px-6 max-w-6xl relative z-10">
        <div class="text-center mb-20">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Built for Power Users</h2>
            <p class="text-xl text-gray-400">Drop the spreadsheets. Stop paying subscriptions.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <!-- Double Entry Analytics -->
            <div class="glass-card md:col-span-2 rounded-2xl p-8 min-h-[320px] flex flex-col justify-end relative">
                <div class="glow-accent top-[-50px] left-[-50px]"></div>
                <div class="relative z-10">
                    <i class="fas fa-chart-pie text-3xl text-blue-400 mb-4"></i>
                    <h3 class="text-2xl font-bold text-white mb-2">Detailed Analytics</h3>
                    <p class="text-gray-400 max-w-md">Break down every expense precisely. Trace money across multiple accounts, credit cards, and cash stashes.</p>
                </div>
            </div>

            <!-- Offline Privacy -->
            <div class="glass-card rounded-2xl p-8 min-h-[320px] group relative overflow-hidden">
                <div class="glow-accent top-[-50px] right-[-50px]"></div>
                
                <!-- Glowing Padlock Hover State -->
                <div class="absolute inset-0 bg-kaasi-card/90 backdrop-blur-sm z-20 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mb-4 shadow-[0_0_30px_rgba(34,197,94,0.4)]">
                        <i class="fas fa-lock text-2xl text-green-400"></i>
                    </div>
                    <p class="text-sm font-bold text-green-400 text-center px-4">Turn off your Wi-Fi right now. Kaasi still works perfectly.</p>
                </div>

                <div class="relative z-10 h-full flex flex-col justify-between">
                    <i class="fas fa-shield-halved text-3xl text-green-400 mb-4"></i>
                    <div>
                        <h3 class="text-2xl font-bold text-white mb-2">100% Offline</h3>
                        <p class="text-gray-400">No sneaky syncing. No cloud lock-in. Your data stays entirely on your device.</p>
                    </div>
                </div>
            </div>

            <!-- Math Engine Playground -->
            <div class="glass-card md:col-span-3 rounded-2xl p-8 border border-orange-500/20 relative">
                <div class="glow-accent bottom-[-100px] left-1/2 -translate-x-1/2 w-[400px]"></div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
                    <div>
                        <i class="fas fa-calculator text-3xl text-kaasi-orange mb-4"></i>
                        <h3 class="text-3xl font-bold text-white mb-4">Built-in Math Engine</h3>
                        <p class="text-gray-400 text-lg mb-6">
                            Stop switching to a calculator app. Type complex mathematical expressions directly into any amount field, and the native recursive descent parser calculates it instantly.
                        </p>
                    </div>
                    
                    <!-- Live Interactive Sandbox -->
                    <div class="bg-[#121212] p-6 rounded-xl border border-gray-800 shadow-inner">
                        <label class="block text-xs font-bold tracking-wider text-gray-500 uppercase mb-3">Try it live</label>
                        <div class="relative flex items-center bg-[#18181b] border border-gray-700 rounded-lg overflow-hidden focus-within:border-kaasi-orange transition-colors">
                            <span class="pl-4 text-gray-500 font-bold">Rs.</span>
                            <input 
                                type="text" 
                                id="bento-math-input" 
                                class="w-full bg-transparent px-3 py-4 text-white font-mono text-lg focus:outline-none placeholder-gray-600" 
                                placeholder="(1500 * 4) + 300"
                                autocomplete="off"
                            >
                        </div>
                        <div class="mt-4 flex items-center justify-between">
                            <span class="text-sm text-gray-500">Evaluates instantly</span>
                            <div id="bento-math-result" class="text-sm text-gray-500 font-mono text-right">Result appears here</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- 3. Competitor Matrix -->
<section class="py-24 bg-zinc-900/40 border-y border-gray-800/50" id="matrix">
    <div class="container mx-auto px-6 max-w-5xl">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold text-white mb-4">How Kaasi Compares</h2>
            <p class="text-lg text-gray-400">The serious choice for managing LKR.</p>
        </div>
        
        <div class="glass-panel rounded-2xl overflow-x-auto shadow-2xl">
            <table class="w-full text-left border-collapse min-w-[600px]">
                <thead>
                    <tr class="border-b border-gray-800 bg-black/40">
                        <th class="p-6 text-white font-bold w-1/3">Feature</th>
                        <th class="p-6 text-kaasi-orange font-bold text-lg w-1/4 bg-orange-500/5">Kaasi</th>
                        <th class="p-6 text-gray-400 font-semibold w-1/4">Basic Apps</th>
                        <th class="p-6 text-gray-400 font-semibold">Spreadsheets</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50 text-gray-300">
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-6 font-medium text-white">Privacy Architecture</td>
                        <td class="p-6 text-green-400 font-medium bg-orange-500/5"><i class="fas fa-lock mr-2"></i> 100% Offline</td>
                        <td class="p-6 text-red-400"><i class="fas fa-cloud mr-2"></i> Cloud-Locked</td>
                        <td class="p-6 text-green-400"><i class="fas fa-file mr-2"></i> Local File</td>
                    </tr>
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-6 font-medium text-white">Platform Independence</td>
                        <td class="p-6 text-green-400 font-medium bg-orange-500/5"><i class="fas fa-check mr-2"></i> Universal Web App</td>
                        <td class="p-6 text-red-400"><i class="fas fa-mobile-alt mr-2"></i> Mobile Only</td>
                        <td class="p-6 text-green-400"><i class="fas fa-laptop mr-2"></i> Desktop Heavy</td>
                    </tr>
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-6 font-medium text-white">Speed & Data Entry</td>
                        <td class="p-6 text-green-400 font-medium bg-orange-500/5"><i class="fas fa-bolt mr-2"></i> Instant + Math Parser</td>
                        <td class="p-6 text-yellow-400"><i class="fas fa-clock mr-2"></i> Moderate</td>
                        <td class="p-6 text-red-400"><i class="fas fa-keyboard mr-2"></i> Slow & Manual</td>
                    </tr>
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-6 font-medium text-white">Pricing Model</td>
                        <td class="p-6 text-green-400 font-medium bg-orange-500/5"><i class="fas fa-gift mr-2"></i> 100% Free, No Ads</td>
                        <td class="p-6 text-red-400"><i class="fas fa-credit-card mr-2"></i> Subscriptions/Ads</td>
                        <td class="p-6 text-green-400"><i class="fas fa-gift mr-2"></i> Free</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- 4. Blog Integration -->
<section class="py-32 bg-kaasi-bg" id="blog">
    <div class="container mx-auto px-6 max-w-6xl">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-4xl font-bold text-white mb-4">Master Your Money</h2>
                <p class="text-lg text-gray-400">Insights from the Kaasi Blog.</p>
            </div>
            <a href="/blog/" class="hidden md:flex items-center gap-2 text-kaasi-orange font-bold hover:text-white transition-colors">
                View all articles <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {% set posts = collections.post | reverse %}
            {% for post in posts.slice(0, 3) %}
            <a href="{{ post.url }}" class="glass-card rounded-2xl group flex flex-col h-full">
                <div class="h-48 overflow-hidden">
                    <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" onerror="this.onerror=null; this.src='https://placehold.co/600x400/18181b/3f3f46?text=Kaasi';">
                </div>
                <div class="p-6 flex flex-col flex-grow">
                    <span class="text-xs font-bold text-kaasi-orange uppercase tracking-wider mb-2">{{ post.date | dateFilter }}</span>
                    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-kaasi-orange transition-colors line-clamp-2">{{ post.data.title }}</h3>
                    <p class="text-gray-400 text-sm mt-auto line-clamp-3">{{ post.data.excerpt }}</p>
                </div>
            </a>
            {% endfor %}
        </div>
        
        <div class="mt-12 text-center md:hidden">
            <a href="/blog/" class="inline-flex items-center gap-2 text-kaasi-orange font-bold hover:text-white transition-colors border border-kaasi-orange/30 px-6 py-3 rounded-full">
                View all articles <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</section>