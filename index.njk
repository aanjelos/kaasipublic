---

<!-- Hero Section -->
<section class="min-h-screen flex items-center justify-center pt-40 pb-20 text-center overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="animate-fade-in-up">
      <img
        src="img/FullLogo.svg"
        alt="Kaasi Logo"
        class="h-12 md:h-16 mx-auto mb-8"
        onerror="this.onerror=null; this.src='https://placehold.co/200x64/121212/e67e26?text=Kaasi&font=satoshi';"
      />
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        The Finance Engine for<br/>Serious Sri Lankans 🇱🇰
      </h1>
      <p class="text-lg md:text-xl text-gray-400 max-w-3xl mx-auto mb-10">
        Simple trackers are great for getting started. Kaasi is for when you need complete control. Track complex expenses, manage debts, credit cards, and installments with a fully offline, zero-ads power tool.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="https://app.kaasi.com.lk/" target="_blank" class="cta-button-large">
          Launch Kaasi
        </a>
        <a href="#features" class="cta-button-secondary">
          Learn More <i class="fas fa-arrow-down ml-2 text-xs"></i>
        </a>
      </div>
    </div>

    <!-- App Mockup -->
    <div class="mt-20 animate-fade-in-up" style="--delay: 0.3s">
      <div id="mockup-container" class="relative mx-auto w-full max-w-4xl">
        <div class="absolute -inset-2">
          <div class="w-full h-full max-w-4xl mx-auto rounded-2xl bg-gradient-to-r from-orange-600 via-orange-400 to-orange-600 opacity-10 blur-3xl"></div>
        </div>
        <img
          id="mockup-image"
          src="img/dash.png"
          onerror="this.onerror=null; this.src='https://placehold.co/1200x600/18181b/3f3f46?text=Kaasi+Dashboard';"
          alt="Kaasi App Dashboard Mockup"
          class="relative w-full h-auto object-cover object-top rounded-xl border-2 border-gray-800/80 shadow-2xl shadow-black/80"
        />
      </div>
    </div>
  </div>
</section>

<!-- Features Section (Bento Grid) -->
<section id="features" class="py-24 md:py-32">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 animate-on-scroll">
        Built for People Who Take Money Seriously
      </h2>
      <p class="text-lg text-gray-400 animate-on-scroll" style="--delay: 0.1s">
        Not a basic tracker. A full financial control centre for your LKR.
      </p>
    </div>

    <div class="flex flex-col gap-6">
      <!-- Top Row -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Card 1: Expense Breakdown -->
        <div class="bento-card lg:col-span-2 animate-on-scroll">
          <i class="fas fa-chart-pie bento-icon text-blue-400"></i>
          <h3 class="bento-title">Detailed Expense Breakdowns</h3>
          <p class="bento-text">
            See every category, every month, broken down precisely. Not just a total, but a full picture of where your money actually went.
          </p>
          <img
            src="img/month.png"
            onerror="this.onerror=null; this.src='https://placehold.co/800x400/18181b/3f3f46?text=Monthly+UI';"
            alt="Monthly Breakdown UI"
            class="bento-image-large"
          />
        </div>

        <!-- Card 2: Privacy -->
        <div class="bento-card animate-on-scroll" style="--delay: 0.1s">
          <i class="fas fa-user-shield bento-icon text-green-400"></i>
          <h3 class="bento-title">Offline-First Privacy</h3>
          <p class="bento-text">
            Your data never silently syncs anywhere. Kaasi works completely offline by default. No account required to get started.
            <button id="open-privacy-policy" class="transition-colors underline font-medium hover:text-orange-500">
              Read the privacy policy here.
            </button>
          </p>
          <div class="mt-4 flex justify-center items-center h-full bg-grid-pattern rounded-lg">
            <i class="fas fa-lock text-6xl text-green-400/50"></i>
          </div>
        </div>
      </div>

      <!-- Middle Row: Power Features -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Card 3: PIN Lock -->
        <div class="bento-card animate-on-scroll" style="--delay: 0.1s">
          <i class="fas fa-shield-halved bento-icon text-yellow-400"></i>
          <h3 class="bento-title">PIN Lock with Secure Recovery</h3>
          <p class="bento-text">
            Lock your financial dashboard with a PIN. Even if you forget it, a secure offline recovery system ensures you never lose your data.
          </p>
        </div>

        <!-- Card 4: Inline Math Engine -->
        <div class="bento-card animate-on-scroll" style="--delay: 0.2s; overflow: visible;">
          <i class="fas fa-calculator bento-icon text-orange-400"></i>
          <h3 class="bento-title">Inline Math Engine</h3>
          <p class="bento-text mb-4">
            No switching to a calculator app. Type expressions directly into amount fields. Try it below:
          </p>
          <div class="relative w-full">
            <input type="text" id="demo-math-input" class="w-full bg-[#121212] border border-gray-700 rounded-lg py-3 px-4 text-white font-mono focus:outline-none focus:border-orange-500 transition-colors pr-12" value="(1500*2)+350" autocomplete="off" />
            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-orange-500 transition-colors focus:outline-none" aria-label="Toggle Calculator">
              <i class="fas fa-calculator"></i>
            </button>
          </div>
        </div>
      </div>

      <!-- Bottom Row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bento-card animate-on-scroll" style="--delay: 0.2s">
          <i class="fas fa-hand-holding-usd bento-icon text-red-400"></i>
          <h3 class="bento-title">Debts &amp; Receivables</h3>
          <p class="bento-text">
            Track what you owe and what you're owed, including partial payments and outstanding balances.
          </p>
        </div>

        <div class="bento-card animate-on-scroll" style="--delay: 0.3s">
          <i class="fas fa-sliders-h bento-icon text-orange-400"></i>
          <h3 class="bento-title">Fully Customizable</h3>
          <p class="bento-text">
            Rename your accounts, create your own expense categories, set credit card limits, and hide sections you don't use.
          </p>
        </div>

        <div class="bento-card animate-on-scroll" style="--delay: 0.4s">
          <i class="fas fa-file-export bento-icon text-purple-400"></i>
          <h3 class="bento-title">Data Portability</h3>
          <p class="bento-text">
            Your entire financial history is yours. Export it, import it, back it up. Full data portability with no lock-in.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why a Web App? Section -->
<section id="why-web" class="py-24 md:py-32 bg-gray-900/20 border-y border-gray-800/60">
  <div class="container mx-auto px-6 max-w-5xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Why a Web App?</h2>
        <div class="space-y-4 text-gray-400 text-lg">
          <p>
            Most finance apps are designed for a small screen and a quick tap. But real budgeting needs real tools. Kaasi works across your phone, tablet, and laptop in the browser you already have. No App Store. No download. No waiting for an update.
          </p>
          <p>
            And because Kaasi is a Progressive Web App, you can still install it directly to your home screen and open it like any other app. The best of both worlds.
          </p>
        </div>
      </div>
      <div class="grid grid-cols-1 gap-4 animate-on-scroll" style="--delay: 0.2s">
        <div class="bento-card !p-5">
          <div class="flex items-center gap-4">
            <i class="fas fa-mobile-alt text-2xl text-orange-400 w-8 text-center flex-shrink-0"></i>
            <div>
              <h4 class="text-white font-semibold">Works on any device</h4>
              <p class="text-gray-400 text-sm">Phone, tablet, or desktop. One tool, every screen.</p>
            </div>
          </div>
        </div>
        <div class="bento-card !p-5">
          <div class="flex items-center gap-4">
            <i class="fas fa-link-slash text-2xl text-green-400 w-8 text-center flex-shrink-0"></i>
            <div>
              <h4 class="text-white font-semibold">Works without internet</h4>
              <p class="text-gray-400 text-sm">Fully offline-capable. Your data never waits on a connection.</p>
            </div>
          </div>
        </div>
        <div class="bento-card !p-5">
          <div class="flex items-center gap-4">
            <i class="fas fa-download text-2xl text-blue-400 w-8 text-center flex-shrink-0"></i>
            <div>
              <h4 class="text-white font-semibold">Installable to home screen</h4>
              <p class="text-gray-400 text-sm">Feels like a native app. No App Store required.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

